        const getDefaultRetryBackoffStrategy = ()=>{
            let delayBase = DEFAULT_RETRY_DELAY_BASE;
            const computeNextBackoffDelay = (attempts)=>Math.floor(Math.min(MAXIMUM_RETRY_DELAY, Math.random() * 2 ** attempts * delayBase));
