                    outputFilterSensitiveLog,
                    [types_dist_es.Vf]: {
                        commandInstance: this,
                        ...smithyContext
                    },
                    ...additionalContext
                };
                const { requestHandler } = configuration;
                return stack.resolve((request)=>requestHandler.handle(request.request, options || {}), handlerExecutionContext);
            }
        }
