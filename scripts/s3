            }
            getSchemaName() {
                const schema = this.getSchema();
                if ("number" == typeof schema) {
                    const _schema = 63 & schema;
                    const container = 192 & schema;
                    const type = Object.entries(SCHEMA).find(([, value])=>value === _schema)?.[0] ?? "Unknown";
                    switch(container){
                        case SCHEMA.MAP_MODIFIER:
                            return `${type}Map`;
                        case SCHEMA.LIST_MODIFIER:
                            return `${type}List`;
