                                if (!it || it.value) fc.items.push({
                                    start: [],
                                    key: fs,
                                    sep: []
                                });
                                else if (it.sep) this.stack.push(fs);
                                else Object.assign(it, {
                                    key: fs,
                                    sep: []
                                });
                                return;
                            }
