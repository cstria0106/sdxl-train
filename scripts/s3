function defineLazy(object, key, getter) {
    let value;
    Object.defineProperty(object, key, {
        get () {
            if (value === EVALUATING) return;
            if (void 0 === value) {
                value = EVALUATING;
                value = getter();
            }
            return value;
        },
        set (v) {
