function parsePositiveInt(v) {
    const n = Number(v);
    if (!Number.isFinite(n) || n <= 0) throw new InvalidArgumentError("expires must be a positive number");
    return Math.floor(n);
}
function loadS3Config(path) {
    const obj = dist.parse((0, external_fs_.readFileSync)(path, "utf-8"));
    const cfg = ConfigSchema.parse(obj);
    const s3 = cfg.s3;
    return {
        ...s3,
        endpoint_url: s3.endpoint_url.replace(/\/+$/, "")
    };
}
function makeClient(s3) {
    return new S3Client({
        region: "auto",
        endpoint: s3.endpoint_url,
        forcePathStyle: true,
        credentials: {
            accessKeyId: s3.access_key,
            secretAccessKey: s3.secret_key
        }
    });
}
async function signPut(client, bucket, key, expires, contentType) {
    const cmd = new PutObjectCommand({
        Bucket: bucket,
        Key: key,
        ContentType: contentType
    });
    return getSignedUrl(client, cmd, {
        expiresIn: expires
    });
}
async function signGet(client, bucket, key, expires, name, responseContentType) {
    const ResponseContentDisposition = name ? `attachment; filename="${name.replace(/"/g, "")}"` : void 0;
    const cmd = new GetObjectCommand({
        Bucket: bucket,
        Key: key,
        ResponseContentDisposition,
        ResponseContentType: responseContentType
    });
    return getSignedUrl(client, cmd, {
        expiresIn: expires
    });
}
