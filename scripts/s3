        function intResolve(str, offset, radix, { intAsBigInt }) {
            const sign = str[0];
            if ('-' === sign || '+' === sign) offset += 1;
            str = str.substring(offset).replace(/_/g, '');
            if (intAsBigInt) {
                switch(radix){
                    case 2:
                        str = `0b${str}`;
                        break;
                    case 8:
                        str = `0o${str}`;
                        break;
                    case 16:
                        str = `0x${str}`;
                        break;
                }
                const n = BigInt(str);
                return '-' === sign ? BigInt(-1) * n : n;
            }
            const n = parseInt(str, radix);
            return '-' === sign ? -1 * n : n;
        }
        function intStringify(node, radix, prefix) {
