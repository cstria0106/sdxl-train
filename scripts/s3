                const it = fc.items[fc.items.length - 1];
                if ('flow-error-end' === this.type) {
                    let top;
                    do {
                        yield* this.pop();
                        top = this.peek(1);
                    }while (top && 'flow-collection' === top.type);
                } else if (0 === fc.end.length) {
                    switch(this.type){
                        case 'comma':
                        case 'explicit-key-ind':
                            if (!it || it.sep) fc.items.push({
                                start: [
                                    this.sourceToken
                                ]
                            });
